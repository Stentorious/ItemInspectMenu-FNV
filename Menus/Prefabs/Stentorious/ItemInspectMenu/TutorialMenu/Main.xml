<_ItemInspectMenu+Controls> <copy src="sibling(HUDMainMenu)" trait="_ItemInspectMenu+Controls" /> </_ItemInspectMenu+Controls>
<_ItemInspectMenu+Name> <copy src="sibling(HUDMainMenu)" trait="_ItemInspectMenu+Name" /> </_ItemInspectMenu+Name>
<_ItemInspectMenu+Description> <copy src="sibling(HUDMainMenu)" trait="_ItemInspectMenu+Description" /> </_ItemInspectMenu+Description>
<_ItemInspectMenu+Vignette> <copy src="sibling(HUDMainMenu)" trait="_ItemInspectMenu+Vignette" /> </_ItemInspectMenu+Vignette>
<_ItemInspectMenu+Init> 0 </_ItemInspectMenu+Init>
<_ItemInspectMenu+Enabled> 0 </_ItemInspectMenu+Enabled>

<rect name="ItemInspectMenu">

	<_Font>
		<copy> 3 </copy>
		<onlyifnot src="globals()" trait="_duiHUDOffset" />
		<add>
			<copy> 6 </copy>
			<onlyif src="globals()" trait="_duiHUDOffset" />
		</add>
	</_Font>

	<visible> <copy src="io()" trait="_ItemInspectMenu+Enabled" /> </visible>

	<text name="Title">
		<visible> <copy src="io()" trait="_ItemInspectMenu+Name" /> </visible>
		<x>
			<copy src="screen()" trait="width" />
			<div> 2 </div>
			<sub> 11 </sub>
		</x>
		<y> 75 </y>
		<justify> &center; </justify>
		<font> 7 </font>
		<zoom> 150 </zoom>
		<string></string>
	</text>

	<text name="Description">
		<visible> <copy src="io()" trait="_ItemInspectMenu+Description" /> </visible>
		<x> <copy src="sibling(Title)" trait="x" /></x>
		<y>
			<copy src="sibling(Title)" trait="y" />
			<add> 100 </add>
		</y>
		<justify> &center; </justify>
		<wrapwidth> 1200 </wrapwidth>
		<font> <copy src="parent()" trait="_Font" /> </font>
		<zoom> 100 </zoom>
		<string></string>
	</text>

	<rect name="Controls">

		<_BackgroundPad> 8 </_BackgroundPad>
		<_TextOffsetY>
			<copy> -5 </copy>
			<onlyif src="globals()" trait="_duiHUDOffset" />
		</_TextOffsetY>
		<_width>
			<copy src="child(Exit)" trait="x" />
			<add src="child(Exit)" trait="width" />
			<add src="me()" trait="_verbuf" />
			<add> 2 </add>
		</_width>
		<_height>
			<copy src="child(Exit)" trait="y" />
			<add src="child(Exit)" trait="height" />
			<sub src="me()" trait="_TextOffsetY" />
			<sub src="me()" trait="_TextOffsetY" />
		</_height>
		<_systemcolor> 1 </_systemcolor>
		<_horbuf> 20 </_horbuf>
		<_verbuf> 15 </_verbuf>

		<visible> <copy src="io()" trait="_ItemInspectMenu+Controls" /> </visible>
		<locus> 1 </locus>
		<x>
			<copy src="screen()" trait="width" />
			<sub src="me()" trait="_width" />
			<div> 2 </div>
		</x>
		<y>
			<copy src="screen()" trait="height" />
			<sub src="child(WindowBackground)" trait="height" />
			<sub> 25 </sub>
		</y>

		<text name="Rotate">
			<visible>
				<copy src="io()" trait="_ItemInspectMenu+Enabled" />
				<neq> 3 </neq>
			</visible>
			<depth> 2 </depth>
			<x> <copy src="parent()" trait="_verbuf" /> </x>
			<y>
				<copy src="parent()" trait="_verbuf" />
				<add src="parent()" trait="_TextOffsetY" />
			</y>
			<font> <copy src="grandparent()" trait="_Font" /> </font>
			<justify> &left; </justify>
			<string> <copy src="me()" trait="_prompt" /> </string>
			<_prompt>
				<copy src="globals" trait="_Has360Controller" />
				<copy src="me()" trait="_prompt_" />
			</_prompt>
			<_prompt_0> Rotate: Mouse) </_prompt_0>
			<_prompt_1> Rotate: RS) </_prompt_1>
		</text>

		<text name="Zoom">
			<visible> 1 </visible>
			<depth> 2 </depth>
			<x>
				<copy src="sibling(Rotate)" trait="width" />
				<add src="parent()" trait="_horbuf" />
				<onlyif src="sibling(Rotate)" trait="visible" />
				<add src="sibling(Rotate)" trait="x" />
			</x>
			<y> <copy src="sibling(Rotate)" trait="y" /> </y>
			<font> <copy src="grandparent()" trait="_Font" /> </font>
			<justify> &left; </justify>
			<string> <copy src="me()" trait="_prompt" /> </string>
			<_prompt>
				<copy src="globals" trait="_Has360Controller" />
				<add>
					<copy> 2 </copy>
					<onlyif>
						<copy src="io()" trait="_ItemInspectMenu+Enabled" />
						<eq> 3 </eq>
					</onlyif>
				</add>
				<copy src="me()" trait="_prompt_" />
			</_prompt>
			<_prompt_0> Zoom: Wheel) </_prompt_0>
			<_prompt_1> Zoom: LT/RT) </_prompt_1>
			<_prompt_2> Take: &-sUActnActivate;) </_prompt_2>
			<_prompt_3> Take: A) </_prompt_3>
		</text>

		<text name="Exit">
			<visible> 1 </visible>
			<depth> 2 </depth>
			<x>
				<copy src="sibling(Zoom)" trait="x" />
				<add src="sibling(Zoom)" trait="width" />
				<add src="parent()" trait="_horbuf" />
			</x>
			<y> <copy src="sibling(Rotate)" trait="y" /> </y>
			<font> <copy src="grandparent()" trait="_Font" /> </font>
			<justify> &left; </justify>
			<string> <copy src="me()" trait="_prompt" /> </string>
			<_prompt>
				<copy src="globals" trait="_Has360Controller" />
				<copy src="me()" trait="_prompt_" />
			</_prompt>
			<_prompt_0> Exit: Tab) </_prompt_0>
			<_prompt_1> Exit: B) </_prompt_1>
		</text>

		<image name="WindowBackground">
			<visible> 1 </visible>
			<alpha> 175 </alpha>
			<depth> 0 </depth>
			<x>
				<copy> 0 </copy>
				<sub src="parent()" trait="_BackgroundPad" />
			</x>
			<y>
				<copy> 0 </copy>
				<sub src="parent()" trait="_BackgroundPad" />
			</y>
			<width>
				<copy src="parent()" trait="_width" />
				<add src="parent()" trait="_BackgroundPad" />
				<add src="parent()" trait="_BackgroundPad" />
			</width>
			<height>
				<copy src="parent()" trait="_height" />
				<add src="parent()" trait="_BackgroundPad" />
				<add src="parent()" trait="_BackgroundPad" />
			</height>
			<zoom> &scale; </zoom>
			<systemcolor> 0 </systemcolor>
			<red> 0 </red>
			<green> 0 </green>
			<blue> 0 </blue>
			<filename> Interface\Shared\solid.dds </filename>
		</image>

		<image name="InnerBackground">
			<visible> 1 </visible>
			<alpha> 30 </alpha>
			<locus> 1 </locus>
			<depth> 1 </depth>
			<x> 0 </x>
			<y> 0 </y>
			<width> <copy src="parent()" trait="_width" /> </width>
			<height> <copy src="parent()" trait="_height" /> </height>
			<zoom> -1 </zoom>
			<brightness> 255 </brightness>
			<filename> Interface\Shared\solid.dds </filename>
		</image>

		<!-- Headlines -->
		<rect name="Headlines">

			<visible> 1 </visible>
			<locus> 1 </locus>
			<depth> 10 </depth>
			<x> 0 </x>
			<y> 0 </y>

			<image name="Headline_VL">
				<x>
					<copy> 0 </copy>
					<sub src="globals()" trait="_line_thickness" />
				</x>
				<width> <copy src="globals()" trait="_line_thickness" /> </width>
				<height> <copy src="grandparent()" trait="_height" /> </height>
				<filename> Interface\Shared\solid.dds </filename>
			</image>
			<image name="Headline_VR">
				<x> <copy src="grandparent()" trait="_width" /> </x>
				<width> <copy src="sibling(Headline_VL)" trait="width" /> </width>
				<height> <copy src="sibling(Headline_VL)" trait="height" /> </height>
				<filename> Interface\Shared\solid.dds </filename>
			</image>
			<image name="Headline_HT">
				<x> <copy src="sibling(Headline_VL)" trait="x" /> </x>
				<y> <copy src="me()" trait="x" /> </y>
				<width>
					<copy src="grandparent()" trait="_width" />
					<add src="globals()" trait="_line_thickness" />
					<add src="globals()" trait="_line_thickness" />
				</width>
				<height> <copy src="globals()" trait="_line_thickness" /> </height>
				<filename> Interface\Shared\solid.dds </filename>
			</image>
			<image name="Headline_HB">
				<x> <copy src="sibling(Headline_HT)" trait="x" /> </x>
				<y> <copy src="grandparent()" trait="_height" /> </y>
				<width> <copy src="sibling(Headline_HT)" trait="width" /> </width>
				<height> <copy src="sibling(Headline_HT)" trait="height" /> </height>
				<filename> Interface\Shared\solid.dds </filename>
			</image>

		</rect>
	</rect>

	<image name="Vignette">
		<visible> 1 </visible>
		<alpha>
			<copy src="io()" trait="_ItemInspectMenu+Vignette" />
			<mul> 2.5 </mul>
		</alpha>
		<depth> -25000 </depth>
		<x> -10 </x>
		<y> -10 </y>
		<width>
			<copy src="screen()" trait="width" />
			<add> 20 </add>
		</width>
		<height>
			<copy src="screen()" trait="height" />
			<add> 20 </add>
		</height>
		<zoom> &scale; </zoom>
		<systemcolor> 0 </systemcolor>
		<red> 0 </red>
		<green> 0 </green>
		<blue> 0 </blue>
		<filename> Interface\Stentorious\_Common\Overlay\vignette.dds </filename>
	</image>

</rect>
