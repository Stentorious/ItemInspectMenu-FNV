{
	"modName": "ItemInspectMenu",
	"displayName": "$modDisplayName",
	"description": "$modDescription",
	"saveFile": "Stentorious/ItemInspectMenu.ini",
	"minMCMVersion": 1.00,
	"minModVersion": 1.00,
	"requirements": [
		{ "type": "file", "file": "NVSE/plugins/scripts/gr_ItemInspectMenu.txt" }
	],
	"submenus": {
		"0": {
			"listTitle": "$modDisplayName",
			"pageTitle": "$modDisplayName",
			"active": 1,
			"columns": 2,
			"enable": 1,
			"options": {
				"1": {
					"title": "$General",
					"enable": 1,
					"type": 0
				},
				"3": {
					"title": "$QuestItems",
					"type": 5,
					"enable": 1,
					"mouse": "$QuestItemsHelp",
					"vars": [{ "form": "Goo1", "auxVar": "*InspectMenu_INI", "key": 7, "configINI": "General:bQuestItems", "default": 1 } ]
				},
				"5": {
					"title": "$UniqueItems",
					"type": 5,
					"enable": 1,
					"mouse": "$UniqueItemsHelp",
					"vars": [{ "form": "Goo1", "auxVar": "*InspectMenu_INI", "key": 8, "configINI": "General:bUniqueItems", "default": 1 } ]
				},

				"9": {
					"title": "$Menu",
					"enable": 1,
					"type": 0
				},
				"11": {
					"title": "$CameraType",
					"type": 6,
					"enable": 1,
					"mouse": "$CameraTypeHelp",
					"vars": [{ "form": "Goo1", "auxVar": "*InspectMenu_INI", "key": 9, "configINI": "Menu:iCameraType", "default": 0 } ],
					"textOff": "$Perspective",
					"textOn": "$Orthographic",
					"call": { "type": "file", "value": "ItemInspectMenu/MCMExtender/UpdateKeybind.gek" }
				},
				"13": {
					"title": "$ShowItemName",
					"enable": 1,
					"type": 5,
					"mouse": "$ShowItemNameHelp",
					"vars": [ { "uiTrait": "HUDMainMenu/_ItemInspectMenu+Name", "configINI": "Menu:bShowItemName", "default": 1 } ]
				},
				"15": {
					"title": "$ShowItemStats",
					"enable": 1,
					"type": 5,
					"mouse": "$ShowItemStatsHelp",
					"vars": [ { "uiTrait": "HUDMainMenu/_ItemInspectMenu+Stats", "configINI": "Menu:bShowItemStats", "default": 1 } ]
				},
				"17": {
					"title": "$ShowItemControls",
					"enable": 1,
					"type": 5,
					"mouse": "$ShowItemControlsHelp",
					"vars": [ { "uiTrait": "HUDMainMenu/_ItemInspectMenu+Controls", "configINI": "Menu:bShowMenuControls", "default": 1 } ]
				},
				"19": {
					"title": "$ShowHUD",
					"type": 5,
					"enable": 1,
					"mouse": "$ShowHUDHelp",
					"vars": [{ "form": "Goo1", "auxVar": "*InspectMenu_INI", "key": 5, "configINI": "Menu:bShowHUD", "default": 1 } ]
				},

				"2": {
					"title": "$Controls",
					"enable": 1,
					"type": 0
				},
				"4": {
					"title": "$Keybind",
					"enable": 1,
					"type": 3,
					"mouse": "$KeybindHelp",
					"vars": [{ "configINI": "Controls:iKeyBind", "default": 20 }],
					"call": { "type": "file", "value": "ItemInspectMenu/MCMExtender/UpdateKeybind.gek" }
				},
				"6": {
					"title": "$InertiaFriction",
					"type": 2.5,
					"enable": 1,
					"suffix": "x",
					"mouse": "$InertiaFrictionHelp",
					"vars": [{ "form": "Goo1", "auxVar": "*InspectMenu_INI", "key": 6, "configINI": "Controls:fInertiaFriction", "default": 1 } ],
					"scale": { "valueDecimal": 2, "valueIncrement": 0.01, "valueMin": 0, "valueMax": 2 }
				},
				"8": {
					"title": "$RotationSensitivityMouse",
					"type": 2.5,
					"enable": 1,
					"suffix": "x",
					"mouse": "$RotationSensitivityHelp",
					"vars": [{ "form": "Goo1", "auxVar": "*InspectMenu_INI", "key": 1, "configINI": "Controls:fSensitivityRotationMouse", "default": 1 } ],
					"scale": { "valueDecimal": 2, "valueIncrement": 0.01, "valueMin": 0.5, "valueMax": 2 }
				},
				"10": {
					"title": "$RotationSensitivityController",
					"type": 2.5,
					"enable": 1,
					"suffix": "x",
					"mouse": "$RotationSensitivityHelp",
					"vars": [{ "form": "Goo1", "auxVar": "*InspectMenu_INI", "key": 2, "configINI": "Controls:fSensitivityRotationController", "default": 1 } ],
					"scale": { "valueDecimal": 2, "valueIncrement": 0.01, "valueMin": 0.5, "valueMax": 2 }
				},
				"12": {
					"title": "$ZoomSensitivityMouse",
					"type": 2.5,
					"enable": 1,
					"suffix": "x",
					"mouse": "$ZoomSensitivityHelp",
					"vars": [{ "form": "Goo1", "auxVar": "*InspectMenu_INI", "key": 3, "configINI": "Controls:fSensitivityZoomMouse", "default": 1 } ],
					"scale": { "valueDecimal": 2, "valueIncrement": 0.01, "valueMin": 0.5, "valueMax": 2 }
				},
				"14": {
					"title": "$ZoomSensitivityController",
					"type": 2.5,
					"enable": 1,
					"suffix": "x",
					"mouse": "$ZoomSensitivityHelp",
					"vars": [{ "form": "Goo1", "auxVar": "*InspectMenu_INI", "key": 4, "configINI": "Controls:fSensitivityZoomController", "default": 1 } ],
					"scale": { "valueDecimal": 2, "valueIncrement": 0.01, "valueMin": 0.5, "valueMax": 2 }
				}
			}
		}
	}
}